#!/usr/bin/env bash

<%
image_path =
  if context.container_image == "custom"
    context.custom_image.to_s.strip
  else
    context.container_image
  end

if image_path.empty?
  raise "Custom image selected but no image path provided"
end
%>

hostname

module load apptainer

export RSTUDIO_AUTH=$PWD/bin/auth
export RSTUDIO_RSESSION=$PWD/rsession.sh

<%= context.custom_environment.gsub(/\r\n?/, "\n") %>

# Generate an rsession wrapper script
(
umask 077
sed 's/^ \{2\}//' > "${RSTUDIO_RSESSION}" << EOL
  #!/bin/bash -l

  export RSESSION_LOG="${PWD}/rsession.log"
  exec &>>"\${RSESSION_LOG}"

  <%= context.custom_environment.gsub(/\r\n?/, "\n") %>

  echo "Launching rsession..."
  set -x
  exec /usr/lib/rstudio-server/bin/rsession "\${@}"
EOL
)
chmod 700 "${RSTUDIO_RSESSION}"

cd $HOME
set -x

apptainer exec \
  --scratch /run,/var/lib/rstudio-server \
  --bind $TMPDIR:/tmp \
  <%= image_path %> \
  rserver \
    --www-port=$port \
    --server-user=$(whoami) \
    --auth-pam-helper-path=$RSTUDIO_AUTH \
    --auth-none=0 \
    --auth-encrypt-password=0 \
    --auth-timeout-minutes=0 \
    --rsession-path=$RSTUDIO_RSESSION
